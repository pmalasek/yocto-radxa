From f4d609dd746b5b74bb64d6e29dd9882e6b3e446c Mon Sep 17 00:00:00 2001
From: "Petr Malasek (Yoga)" <petr.malasek@xtuning.cz>
Date: Fri, 24 Apr 2026 14:33:51 +0200
Subject: [PATCH] arm64: dts: amlogic: meson-g12a-radxa-zero: add MCP2515 CAN

Enable MCP2515 CAN controller connected on SPICC0 (GPIOX bank):
- 20MHz fixed clock oscillator
- IRQ on GPIOX_7 / header pin 18 (falling edge)
- SPI on GPIOX_8/9/11 (MOSI/MISO/CLK), CS on GPIOX_10

Upstream-Status: Inappropriate [board-specific DTS customization for Radxa Zero BSP]
---
 .../dts/amlogic/meson-g12a-radxa-zero.dts     | 25 +++++++++++++++++++
 1 file changed, 25 insertions(+)

diff --git a/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts b/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts
index fcd7e1d8e16f..2ac5224998ca 100644
--- a/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts
+++ b/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts
@@ -8,6 +8,7 @@
 #include "meson-g12a.dtsi"
 #include <dt-bindings/gpio/meson-g12a-gpio.h>
 #include <dt-bindings/sound/meson-g12a-tohdmitx.h>
+#include <dt-bindings/interrupt-controller/irq.h>
 
 / {
 	compatible = "radxa,zero", "amlogic,g12a";
@@ -182,6 +183,12 @@ codec {
 		};
 	};
 
+        can0_osc: can0_osc {
+                compatible = "fixed-clock";
+                #clock-cells = <0>;
+                clock-frequency = <20000000>;
+        };
+
 	wifi32k: wifi32k {
 		compatible = "pwm-clock";
 		#clock-cells = <0>;
@@ -401,3 +408,21 @@ &uart_AO {
 &usb {
 	status = "okay";
 };
+
+&spicc1 {
+        status = "okay";
+        pinctrl-names = "default";
+        pinctrl-0 = <&spicc1_pins>;
+        cs-gpios = <&gpio GPIOH_6 GPIO_ACTIVE_LOW>;
+        #address-cells = <1>;
+        #size-cells = <0>;
+
+        can0: can@0 {
+                compatible = "microchip,mcp2515";
+                reg = <0>;
+                spi-max-frequency = <1000000>;
+                interrupt-parent = <&gpio_intc>;
+                interrupts = <GPIOX_8 IRQ_TYPE_EDGE_FALLING>;
+                clocks = <&can0_osc>;
+        };
+};
-- 
2.51.0

