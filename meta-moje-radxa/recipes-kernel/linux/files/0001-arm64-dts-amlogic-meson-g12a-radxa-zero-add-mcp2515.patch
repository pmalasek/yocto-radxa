From 9aca59bc6a450828a10d3a9df744e4635a53e1d0 Mon Sep 17 00:00:00 2001
From: "Petr Malasek (Yoga)" <petr.malasek@xtuning.cz>
Date: Fri, 24 Apr 2026 13:11:18 +0200
Subject: [PATCH] arm64: dts: amlogic: meson-g12a-radxa-zero: add MCP2515 CAN

Enable an MCP2515 controller connected on SPICC1 CS0 with:
- 20MHz fixed clock
- IRQ on GPIOX_8 (falling edge)
---
 .../dts/amlogic/meson-g12a-radxa-zero.dts     | 35 +++++++++++++++++++
 1 file changed, 35 insertions(+)

diff --git a/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts b/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts
index fcd7e1d8e16f..e361b5013919 100644
--- a/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts
+++ b/arch/arm64/boot/dts/amlogic/meson-g12a-radxa-zero.dts
@@ -8,6 +8,7 @@
 #include "meson-g12a.dtsi"
 #include <dt-bindings/gpio/meson-g12a-gpio.h>
 #include <dt-bindings/sound/meson-g12a-tohdmitx.h>
+#include <dt-bindings/interrupt-controller/irq.h>
 
 / {
 	compatible = "radxa,zero", "amlogic,g12a";
@@ -188,6 +189,13 @@ wifi32k: wifi32k {
 		clock-frequency = <32768>;
 		pwms = <&pwm_ef 0 30518 0>; /* PWM_E at 32.768KHz */
 	};
+
+	can0_osc: can0-osc {
+		compatible = "fixed-clock";
+		#clock-cells = <0>;
+		clock-frequency = <20000000>;
+		clock-output-names = "can0-osc";
+	};
 };
 
 &arb {
@@ -277,6 +285,17 @@ &ir {
 	pinctrl-names = "default";
 };
 
+&periphs_pinctrl {
+	mcp2515_int_pins: mcp2515-int-pins {
+		mux {
+			groups = "GPIOX_8";
+			function = "gpio_periphs";
+			bias-pull-up;
+			drive-strength-microamp = <4000>;
+		};
+	};
+};
+
 &pwm_AO_cd {
 	pinctrl-0 = <&pwm_ao_d_e_pins>;
 	pinctrl-names = "default";
@@ -376,6 +395,22 @@ &tdmout_b {
 &tohdmitx {
 	status = "okay";
 };
+&spicc1 {
+	status = "okay";
+	pinctrl-names = "default";
+	pinctrl-0 = <&spicc1_pins>, <&spicc1_ss0_pins>;
+	#address-cells = <1>;
+	#size-cells = <0>;
+
+	can0: can@0 {
+		compatible = "microchip,mcp2515";
+		reg = <0>;
+		spi-max-frequency = <10000000>;
+		interrupt-parent = <&gpio_intc>;
+		interrupts = <GPIOX_8 IRQ_TYPE_EDGE_FALLING>;
+		clocks = <&can0_osc>;
+	};
+};
 
 &uart_A {
 	status = "okay";
-- 
2.51.0

